{
  "artifacts_dir": "../outputs/my_test_run",
  "output_dir": "../outputs/my_test_run",
  "clustering_method": "graph",
  "similarity_threshold": 0.94,
  "max_time_gap_seconds": 30.0,
  "time_filter_required": true,
  "timestamp_fallback_mode": "none",
  "filename_order_window": 3,
  "enrich_missing_timestamps": true,
  "dbscan_eps": 0.1,
  "dbscan_min_samples": 2,
  "minimum_cluster_size": 1,
  "use_perceptual_hash_filter": false,
  "max_hash_distance": 8,
  "hash_size": 8,
  "use_akaze_verifier": false,
  "akaze_max_side": 1024,
  "akaze_ratio_test_threshold": 0.8,
  "akaze_min_good_matches": 12,
  "akaze_min_inliers": 8,
  "akaze_min_inlier_ratio": 0.4,
  "representative_gate_enabled": true,
  "representative_gate_min_cluster_size": 5,
  "representative_min_matches": 2,
  "cluster_relink_enabled": false,
  "cluster_relink_similarity_threshold": 0.98,
  "cluster_relink_centroid_threshold": 0.96,
  "cluster_relink_max_sequence_gap": 96,
  "cluster_relink_min_matches": 2,
  "metadata_filename": "images.csv",
  "embeddings_filename": "embeddings.npy",
  "image_ids_filename": "image_ids.json",
  "clusters_filename": "clusters.csv",
  "summary_filename": "cluster_summary.json",
  "report_filename": "clusters_report.txt",
  "log_level": "INFO"
}
